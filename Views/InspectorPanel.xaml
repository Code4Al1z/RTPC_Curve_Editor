<UserControl x:Class="RTPCCurveEditor.Views.InspectorPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

  <Border Background="#13131A" BorderBrush="#2A2A38" BorderThickness="1,0,0,0">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
      <StackPanel Margin="12,10">

        <!-- Section: Selected point -->
        <TextBlock Text="POINT" FontSize="10" FontWeight="SemiBold"
                   Foreground="#4A4860" Margin="0,0,0,8"/>

        <Grid Margin="0,0,0,4">
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="32"/>
            <ColumnDefinition Width="*"/>
          </Grid.ColumnDefinitions>
          <Label Content="X" Grid.Column="0" VerticalAlignment="Center"/>
          <TextBox Grid.Column="1"
                   Text="{Binding SelectedPoint.X, StringFormat=F4,
                          UpdateSourceTrigger=PropertyChanged, FallbackValue='—'}"
                   IsEnabled="{Binding SelectedPoint, Converter={StaticResource NullToBool}}"/>
        </Grid>

        <Grid Margin="0,0,0,12">
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="32"/>
            <ColumnDefinition Width="*"/>
          </Grid.ColumnDefinitions>
          <Label Content="Y" Grid.Column="0" VerticalAlignment="Center"/>
          <TextBox Grid.Column="1"
                   Text="{Binding SelectedPoint.Y, StringFormat=F4,
                          UpdateSourceTrigger=PropertyChanged, FallbackValue='—'}"
                   IsEnabled="{Binding SelectedPoint, Converter={StaticResource NullToBool}}"/>
        </Grid>

        <Separator/>

        <!-- Section: Curve -->
        <TextBlock Text="CURVE" FontSize="10" FontWeight="SemiBold"
                   Foreground="#4A4860" Margin="0,10,0,8"/>

        <Label Content="Name" Margin="0,0,0,2"/>
        <TextBox Text="{Binding ActiveCurve.Name, UpdateSourceTrigger=PropertyChanged}"
                 Margin="0,0,0,8"/>

        <Label Content="Colour hex" Margin="0,0,0,2"/>
        <TextBox Text="{Binding ActiveCurve.ColorHex, UpdateSourceTrigger=PropertyChanged}"
                 Margin="0,0,0,12"/>

        <Separator/>

        <!-- Section: RTPC mapping -->
        <TextBlock Text="RTPC MAPPING" FontSize="10" FontWeight="SemiBold"
                   Foreground="#4A4860" Margin="0,10,0,8"/>

        <Label Content="Wwise RTPC name" Margin="0,0,0,2"/>
        <TextBox Text="{Binding Document.WwiseRtpcName, UpdateSourceTrigger=PropertyChanged}"
                 Margin="0,0,0,8"/>

        <Grid Margin="0,0,0,4">
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="8"/>
            <ColumnDefinition Width="*"/>
          </Grid.ColumnDefinitions>
          <StackPanel Grid.Column="0">
            <Label Content="Input min"/>
            <TextBox Text="{Binding Document.InputMin, UpdateSourceTrigger=PropertyChanged}"/>
          </StackPanel>
          <StackPanel Grid.Column="2">
            <Label Content="Input max"/>
            <TextBox Text="{Binding Document.InputMax, UpdateSourceTrigger=PropertyChanged}"/>
          </StackPanel>
        </Grid>

        <Grid Margin="0,0,0,12">
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="8"/>
            <ColumnDefinition Width="*"/>
          </Grid.ColumnDefinitions>
          <StackPanel Grid.Column="0">
            <Label Content="Output min"/>
            <TextBox Text="{Binding Document.OutputMin, UpdateSourceTrigger=PropertyChanged}"/>
          </StackPanel>
          <StackPanel Grid.Column="2">
            <Label Content="Output max"/>
            <TextBox Text="{Binding Document.OutputMax, UpdateSourceTrigger=PropertyChanged}"/>
          </StackPanel>
        </Grid>

        <Separator/>

        <!-- Section: Comparison curves -->
        <TextBlock Text="COMPARISON CURVES" FontSize="10" FontWeight="SemiBold"
                   Foreground="#4A4860" Margin="0,10,0,8"/>

        <ItemsControl ItemsSource="{Binding AllCurves}">
          <ItemsControl.ItemTemplate>
            <DataTemplate>
              <Border Margin="0,2" Padding="8,6" CornerRadius="4"
                      BorderBrush="#2A2A38" BorderThickness="1">
                <Grid>
                  <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="10"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                  </Grid.ColumnDefinitions>
                  <Rectangle Grid.Column="0" Width="8" Height="8" RadiusX="2" RadiusY="2"
                             VerticalAlignment="Center" Margin="0,0,6,0">
                    <Rectangle.Fill>
                      <SolidColorBrush Color="{Binding ColorHex}"/>
                    </Rectangle.Fill>
                  </Rectangle>
                  <TextBlock Grid.Column="1" Text="{Binding Name}"
                             FontSize="12" VerticalAlignment="Center"/>
                  <CheckBox Grid.Column="2" IsChecked="{Binding IsVisible}"
                            VerticalAlignment="Center"/>
                </Grid>
              </Border>
            </DataTemplate>
          </ItemsControl.ItemTemplate>
        </ItemsControl>

        <Button Content="+ Add curve"
                Command="{Binding AddComparisonCurveCommand}"
                Style="{StaticResource GhostButton}"
                Margin="0,8,0,0"/>

        <Separator Margin="0,12,0,8"/>

        <!-- Export shortcuts -->
        <TextBlock Text="EXPORT" FontSize="10" FontWeight="SemiBold"
                   Foreground="#4A4860" Margin="0,0,0,8"/>

        <Button Content="Export Wwise XML"
                Command="{Binding ExportWwiseXmlCommand}"
                Style="{StaticResource GhostButton}"
                Margin="0,0,0,4"/>
        <Button Content="Export JSON"
                Command="{Binding ExportJsonCommand}"
                Style="{StaticResource GhostButton}"
                Margin="0,0,0,4"/>
        <Button Content="Export PNG"
                Command="{Binding ExportPngCommand}"
                Style="{StaticResource GhostButton}"
                Margin="0,0,0,0"/>

      </StackPanel>
    </ScrollViewer>
  </Border>
</UserControl>
