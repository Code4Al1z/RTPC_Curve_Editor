<UserControl x:Class="RTPCCurveEditor.Views.CurveCanvasControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:skia="clr-namespace:SkiaSharp.Views.WPF;assembly=SkiaSharp.Views.WPF">

  <Border Background="#17171F" BorderBrush="#2A2A38" BorderThickness="1" Margin="0">
    <skia:SKElement x:Name="SkiaElement"
                    PaintSurface="OnPaintSurface"
                    MouseLeftButtonDown="OnMouseDown"
                    MouseLeftButtonUp="OnMouseUp"
                    MouseMove="OnMouseMove"
                    MouseRightButtonDown="OnRightMouseDown"
                    MouseWheel="OnMouseWheel"
                    Cursor="Cross"/>
  </Border>
</UserControl>
