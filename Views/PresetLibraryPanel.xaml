<UserControl x:Class="RTPCCurveEditor.Views.PresetLibraryPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

  <Border Background="#13131A" BorderBrush="#2A2A38" BorderThickness="0,0,1,0">
    <DockPanel Margin="0">

      <!-- Header -->
      <Border DockPanel.Dock="Top"
              BorderBrush="#2A2A38" BorderThickness="0,0,0,1" Padding="12,10">
		  <TextBlock Text="PRESETS" FontSize="10" FontWeight="SemiBold"
			 Foreground="#4A4860"/>
      </Border>

      <!-- Search -->
      <Border DockPanel.Dock="Top" Padding="8,8,8,4">
        <TextBox Text="{Binding PresetFilter, UpdateSourceTrigger=PropertyChanged}"
                 Tag="Search presets…">
          <TextBox.Style>
            <Style TargetType="TextBox" BasedOn="{StaticResource {x:Type TextBox}}">
              <Style.Triggers>
                <Trigger Property="Text" Value="">
                  <Setter Property="Background">
                    <Setter.Value>
                      <VisualBrush AlignmentX="Left" AlignmentY="Center" Stretch="None">
                        <VisualBrush.Visual>
                          <TextBlock Text="Search presets…" Foreground="#4A4860"
                                     FontSize="12" Margin="2,0"/>
                        </VisualBrush.Visual>
                      </VisualBrush>
                    </Setter.Value>
                  </Setter>
                </Trigger>
              </Style.Triggers>
            </Style>
          </TextBox.Style>
        </TextBox>
      </Border>

      <!-- Apply button -->
      <Border DockPanel.Dock="Bottom" Padding="8,6">
        <Button Content="Apply Preset"
                Command="{Binding ApplyPresetCommand}"
                Style="{StaticResource PrimaryButton}"/>
      </Border>

      <!-- Preset description -->
      <Border DockPanel.Dock="Bottom" Padding="10,6" MinHeight="52"
              BorderBrush="#2A2A38" BorderThickness="0,1,0,0">
        <TextBlock Text="{Binding SelectedPreset.Description}"
                   TextWrapping="Wrap" FontSize="11"
                   Foreground="#5A5870"/>
      </Border>

      <!-- List -->
      <ScrollViewer VerticalScrollBarVisibility="Auto">
        <ListBox ItemsSource="{Binding FilteredPresets}"
                 SelectedItem="{Binding SelectedPreset}"
                 Margin="4,0">
          <ListBox.GroupStyle>
            <GroupStyle>
              <GroupStyle.HeaderTemplate>
                <DataTemplate>
					<TextBlock Text="{Binding Name}"
			         FontSize="10" FontWeight="SemiBold"
			         Foreground="#4A4860" Margin="6,8,0,2"/>
                </DataTemplate>
              </GroupStyle.HeaderTemplate>
            </GroupStyle>
          </ListBox.GroupStyle>
          <ListBox.ItemTemplate>
            <DataTemplate>
              <TextBlock Text="{Binding Name}" FontSize="12"/>
            </DataTemplate>
          </ListBox.ItemTemplate>
        </ListBox>
      </ScrollViewer>

    </DockPanel>
  </Border>
</UserControl>
